# Revolut X credentials
# Required for live mode. Optional in DRY_RUN mock mode.
REVX_API_KEY=
# Base64-encoded Ed25519 private key material. Supports:
# 1) raw 32-byte seed (base64)
# 2) raw 64-byte secret key (base64)
# 3) PEM text base64-encoded
REVX_PRIVATE_KEY_BASE64=
# Optional: path to PEM private key file (takes precedence over REVX_PRIVATE_KEY_BASE64)
REVX_PRIVATE_KEY_PATH=

# Confirm against current Revolut X docs for your environment.
REVX_BASE_URL=https://revx.revolut.com
SYMBOL=BTC-USD

# Capital envelope
CASH_RESERVE_USD=40
WORKING_CAP_USD=100

# Maker v2 quoting
LEVELS=2
LEVEL_QUOTE_SIZE_USD=8
BASE_HALF_SPREAD_BPS=18
LEVEL_STEP_BPS=10
REFRESH_SECONDS=2
REPRICE_MOVE_BPS=10
QUEUE_REFRESH_SECONDS=90
MIN_HALF_SPREAD_BPS=4
MAX_HALF_SPREAD_BPS=20
CALM_VOL_BPS=15
ENABLE_TOPOFBOOK=false
TOB_QUOTE_SIZE_USD=3
TOB_MAX_VOL_BPS=35
TOB_QUOTE_SIZE_USD_NORMAL=3
TOB_MAX_INVENTORY_RATIO_FOR_BOTH=0.25
TOB_MAX_INVENTORY_RATIO_FOR_ONE_SIDED=0.60
SELL_THROTTLE_BELOW_LOWGATE=true
MIN_SELL_LEVELS_BELOW_LOWGATE=1
SELL_DISABLE_BELOW_NOTIONAL_USD=10
ADAPTIVE_SPREAD=true
ADAPTIVE_STEP_BPS=1
TARGET_FILLS_PER_HOUR=3
TARGET_FILLS_WINDOW_MINUTES=60
FILL_DROUGHT_MINUTES=30
EDGE_LOOKBACK_MINUTES=60
EDGE_GOOD_BPS=8
EDGE_BAD_BPS=0
EDGE_ADJUST_BPS=2
EDGE_MAX_SIDE_ADJUST_BPS=6
TRACK_POSTONLY_REJECTS=true
MAX_CANCELS_PER_HOUR=200
SIGNALS_ENABLED=true
SIGNAL_MAX_SKEW_BPS=10
SIGNAL_ZSCORE_TO_SKEW=4
SIGNAL_DRIFT_TO_SKEW=0.25
SIGNAL_CALM_TIGHTEN=0.85
SIGNAL_HOT_WIDEN=1.25
SIGNAL_HOT_REGIME_MULTIPLIER=2.5
SIGNAL_TOPOFBOOK_ONLY_IN_CALM=true
SIGNAL_LEVELS_IN_HOT=1

# Spread control
# Inside spread is not the edge by itself for this strategy.
MIN_INSIDE_SPREAD_BPS=0.5
MIN_VOL_MOVE_BPS_TO_QUOTE=5
VOL_WINDOW_SECONDS=60
VOL_PAUSE_BPS=70
VOL_SPREAD_MULT_MIN=1.0
VOL_SPREAD_MULT_MAX=2.2

# Toxicity / trend guard
TREND_WINDOW_SECONDS=15
TREND_PAUSE_BPS=20
TREND_SKEW_BPS=10
# spread | reduce_level
TREND_PROTECTION_MODE=spread

# Inventory skew
DYNAMIC_TARGET_BTC=true
DYNAMIC_TARGET_BUFFER_USD=40
TARGET_BTC_NOTIONAL_USD=80
MAX_BTC_NOTIONAL_USD=120
SKEW_MAX_BPS=25
MIN_QUOTE_SIZE_USD=3
MIN_ORDER_AGE_SECONDS=7

# Risk / safety
MAX_CONSECUTIVE_ERRORS=3
PAUSE_SECONDS_ON_VOL=300
MAX_ACTIVE_ORDERS=10
CANCEL_RETRY=2
PLACE_RETRY=2
MAX_ACTIONS_PER_LOOP=4
PNL_DAILY_STOP_USD=-5

# Metrics
METRICS_LOG_EVERY_SECONDS=30

KILL_SWITCH_FILE=./KILL
PAUSE_SWITCH_FILE=./PAUSE
DRY_RUN=true

# Optional runtime settings
# json (default) | sqlite
STORE_BACKEND=json
DEBUG_BALANCES=false
DB_PATH=./revx-bot.sqlite
LOG_LEVEL=info
REQUESTS_PER_MINUTE=800
RECONCILE_SECONDS=5
DASHBOARD_ENABLED=true
DASHBOARD_PORT=8787
MAX_UI_EVENTS=500
MAX_EQUITY_POINTS=5000
EQUITY_SAMPLE_MS=2000
PERSIST_EQUITY_SERIES=false
MAX_API_EVENTS=500
EVENT_DEDUPE=true

# Optional env loader diagnostics
ENV_FILE_PATH=.env
