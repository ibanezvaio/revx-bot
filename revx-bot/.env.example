# Revolut X credentials
# Required for live mode. Optional in DRY_RUN mock mode.
REVX_API_KEY=
# Base64-encoded Ed25519 private key material. Supports:
# 1) raw 32-byte seed (base64)
# 2) raw 64-byte secret key (base64)
# 3) PEM text base64-encoded
REVX_PRIVATE_KEY_BASE64=
# Optional: path to PEM private key file (takes precedence over REVX_PRIVATE_KEY_BASE64)
REVX_PRIVATE_KEY_PATH=

# Confirm against current Revolut X docs for your environment.
REVX_BASE_URL=https://revx.revolut.com
# Enable structured request logs for RevX/Polymarket clients.
DEBUG_HTTP=false
# If true, startup sanity checks must pass (Gamma/CLOB probes) or startup fails.
STRICT_SANITY_CHECK=false
# Optional safety override: when true, skip fills endpoint probing and disable fills reconciliation.
REVX_DISABLE_FILLS_RECONCILE=false
# Preferred flag name (alias of REVX_DISABLE_FILLS_RECONCILE).
DISABLE_FILLS_RECONCILE=false
SYMBOL=BTC-USD

# Capital envelope
