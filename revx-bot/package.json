  "dependencies": {
    "@polymarket/clob-client": "^5.5.0",
    "dotenv": "^16.4.7",
    "ethers": "^6.16.0",
    "pino": "^9.7.0",
    "tweetnacl": "^1.0.3",
    "undici": "^6.21.0",
    "viem": "^2.46.3",
    "zod": "^3.24.2"
