{
  "name": "revx-bot",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "npm run build && node dist/main.js",
    "live": "cross-env DRY_RUN=false npm run build && cross-env DRY_RUN=false node dist/main.js",
    "start": "node dist/main.js",
    "cli": "node dist/cli.js",
    "polymarket": "npm run build && node dist/cli.js polymarket --btc5m --paper",
