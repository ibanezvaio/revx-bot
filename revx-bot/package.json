{
  "name": "revx-bot",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "npm run build && node dist/main.js",
    "live": "cross-env DRY_RUN=false npm run build && cross-env DRY_RUN=false node dist/main.js",
    "start": "node dist/main.js",
    "cli": "node dist/cli.js",
    "status": "node dist/cli.js status",
    "balances": "node dist/cli.js balances --raw",
    "cancel-all": "node dist/cli.js cancel-all",
    "dry-run": "node dist/cli.js dry-run",
    "simulate": "node dist/cli.js simulate --minutes 5",
    "signal-smoke": "npm run build && node dist/scripts/signal-smoke.js",
    "test:elite-signals": "npm run build && node dist/scripts/testEliteSignals.js",
    "test:fair-price": "npm run build && node dist/scripts/testFairPriceModel.js",
    "test:adverse-selection": "npm run build && node dist/scripts/testAdverseSelection.js",
    "test:adverse-guard": "npm run build && node dist/scripts/testAdverseSelectionGuard.js",
    "test:news-scorer": "npm run build && node dist/scripts/testNewsScorer.js",
    "test:news-engine": "npm run build && node dist/scripts/testNewsEngine.js",
    "test:news-guard": "npm run build && node dist/scripts/testNewsGuard.js",
    "test:intel-cluster": "npm run build && node dist/scripts/testIntelClusterPosture.js",
    "test:intel-smoke": "npm run build && node dist/scripts/testIntelConsoleSmoke.js",
    "test:signals-scorer": "npm run build && node dist/scripts/testSignalsScorer.js",
    "test:signals-aggregate": "npm run build && node dist/scripts/testSignalsAggregate.js",
    "test:signals-guard": "npm run build && node dist/scripts/testSignalsGuard.js",
    "test:cancel-idempotency": "npm run build && node dist/scripts/testCancelIdempotency.js",
    "test:adaptive-events": "npm run build && node dist/scripts/testAdaptiveAndEvents.js",
    "test:runtime-overrides": "npm run build && node dist/scripts/testRuntimeOverrides.js",
    "test:quote-plan": "npm run build && node dist/scripts/testQuotePlan.js",
    "test:balance-seeding": "npm run build && node dist/scripts/testBalanceAliasAndSeeding.js",
    "test:performance-analysis": "npm run build && node dist/scripts/testPerformanceAnalysis.js",
    "analysis-smoke": "npm run build && node dist/scripts/analysis_smoke_test.js"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "pino": "^9.7.0",
    "tweetnacl": "^1.0.3",
    "undici": "^6.21.0",
    "zod": "^3.24.2"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.10.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.17.19",
    "cross-env": "^7.0.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
