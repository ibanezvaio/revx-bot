    "test:polymarket-prob": "npm run build && node dist/scripts/testPolymarketProbModel.js",
    "test:polymarket-prob-calibrated": "npm run build && node dist/polymarket/__tests__/ProbModelCalibrated.test.js",
    "test:polymarket-lagprofiler": "npm run build && node dist/polymarket/__tests__/LagProfiler.test.js",
    "test:polymarket-strategy": "npm run build && node dist/scripts/testPolymarketStrategy.js",
    "test:polymarket-sizing": "npm run build && node dist/scripts/testPolymarketSizing.js",
